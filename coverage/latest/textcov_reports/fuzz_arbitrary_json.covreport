  344|       |
  345|  74.4k|        while (bytes_consumed < mem::size_of::<T>())
  346|  74.4k|            && (delta >> T::Unsigned::from_usize(bytes_consumed * 8)) > T::Unsigned::ZERO
  347|       |        {
