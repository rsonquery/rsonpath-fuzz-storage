   17|       |            Leaf(LeafValue),
   18|       |            Nested(NestedValue),
   19|       |        }
   20|       |
   21|       |        #[derive(Arbitrary)]
   22|       |        enum LeafValue {
   23|       |            Null,
   24|       |            Bool(bool),
   25|       |            Integer(i64),
   26|       |            Float(f64),
   27|       |            String(String),
   28|       |        }
   29|       |
   30|       |        enum NestedValue {
   31|       |            Array(Vec<RawValue>),
   32|       |            Object(HashMap<String, RawValue>),
   33|       |        }
   34|       |
   35|       |        impl From<RawValue> for serde_json::Value {
   36|       |            fn from(value: RawValue) -> Self {
   37|       |                match value {
   38|       |                    RawValue::Leaf(LeafValue::Null) => serde_json::Value::Null,
   39|       |                    RawValue::Leaf(LeafValue::Bool(b)) => serde_json::Value::Bool(b),
   40|       |                    RawValue::Leaf(LeafValue::Integer(n)) => serde_json::Value::from(n),
   41|       |                    RawValue::Leaf(LeafValue::Float(f)) => serde_json::Value::from(f),
   42|       |                    RawValue::Leaf(LeafValue::String(s)) => serde_json::Value::String(s),
   43|       |                    RawValue::Nested(NestedValue::Array(arr)) => {
   44|       |                        serde_json::Value::Array(arr.into_iter().map(|x| x.into()).collect())
   45|       |                    }
   46|       |                    RawValue::Nested(NestedValue::Object(obj)) => {
   47|       |                        serde_json::Value::Object(obj.into_iter().map(|x| (x.0, x.1.into())).collect())
   48|       |                    }
   49|       |                }
   50|       |            }
   51|       |        }
   52|       |
   53|       |        fn generate_json_with_size(u: &mut Unstructured, size: usize) -> arbitrary::Result<RawValue> {
   54|       |            if size == 1 && u.arbitrary::<bool>()? {
   55|       |                Ok(RawValue::Leaf(u.arbitrary::<LeafValue>()?))
   56|       |            } else {
   57|       |                let mut rem_size = size - 1;
   58|       |                if u.arbitrary::<bool>()? {
   59|       |                    // Array.
   60|       |                    let mut nested_values = vec![];
   61|       |                    while rem_size > 0 {
   62|       |                        let nested_size = u.int_in_range(1..=rem_size)?;
   63|       |                        rem_size -= nested_size;
   64|       |                        nested_values.push(generate_json_with_size(u, nested_size)?);
   65|       |                    }
   66|       |                    Ok(RawValue::Nested(NestedValue::Array(nested_values)))
   67|       |                } else {
