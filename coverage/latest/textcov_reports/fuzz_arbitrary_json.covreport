   69|       |                    // We generate arbitrary labels and values.
   70|       |                    // We can't guarantee Unstructured won't start returning the same repeat label at some point.
   71|       |                    // In that case, we most likely ran out of bytes in the source. We apply a "good-enough-effort"
   72|       |                    // strategy - append the index number to the end of the label, insert it, if it overwrites something
   73|       |                    // then too bad.
   74|       |                    let mut object = HashMap::new();
   75|       |                    let mut i = 0;
   76|       |                    while rem_size > 0 {
   77|       |                        let nested_size = u.int_in_range(1..=rem_size)?;
   78|       |                        rem_size -= nested_size;
   79|       |                        let value = generate_json_with_size(u, nested_size)?;
   80|       |                        let mut key = u.arbitrary::<String>()?;
   81|       |                        if object.contains_key(&key) {
   82|       |                            key += &i.to_string();
   83|       |                        }
   84|       |                        object.insert(key, value);
   85|       |                        i += 1;
   86|       |                    }
   87|       |                    Ok(RawValue::Nested(NestedValue::Object(object)))
   88|       |                }
   89|       |            }
   90|       |        }
   91|       |
   92|  2.51k|        let size = u.int_in_range(1..=MAX_SIZE)?;
   93|  2.51k|        Ok(ArbitraryJson(generate_json_with_size(u, size)?.into()))
   94|  2.51k|    }
