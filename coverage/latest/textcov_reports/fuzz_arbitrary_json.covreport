  352|      0|                        Err(err) => writeln!(&mut file, "Arbitrary Error: {}", err),
  353|       |                    })
  354|      0|                    .expect("failed to write to `RUST_LIBFUZZER_DEBUG_PATH` file");
  355|      0|                    return -1;
  356|  2.51k|                }
  357|       |
  358|  2.51k|                let data = match data {
  359|  2.51k|                    Ok(d) => d,
  360|      0|                    Err(_) => return -1,
  361|       |                };
  362|       |
  363|  2.51k|                let result = ::libfuzzer_sys::Corpus::from(__libfuzzer_sys_run(data));
