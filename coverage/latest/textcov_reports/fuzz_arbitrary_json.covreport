  217|   470k|    fn overlap_with(&self, other: &Self) -> Option<Self> {
  218|       |        // Assume the first set starts not-later, otherwise flip.
  219|   470k|        if self.start() > other.start() {
  220|   195k|            return other.overlap_with(self);
  221|   274k|        }
  222|   274k|        assert_ne!(self.step().as_u64(), 0, "empty sets must be discarded on construction");
  223|   274k|        assert_ne!(other.step().as_u64(), 0, "empty sets must be discarded on construction");
  224|       |
  225|       |        // First we take both sets as if they are open-ended and linear.
  226|       |        // We can take an overlap under that assumption and then simply apply the lower of the two end constraints,
  227|       |        // if any, to obtain the ultimate result.
  228|       |        //
  229|       |        // If first_element is beyond the range of JsonUInt it will fail conversion at the end of this function,
  230|       |        // and result in an empty set (empty transition = no transition). This is correct behavior - first element
  231|       |        // out of bounds means there are no valid elements.
