  507|       |                if negated {
  508|       |                    return fail(SyntaxErrorKind::InvalidNegation, q.len(), 1, rest);
  509|       |                } else {
  510|       |                    return Ok((
  511|       |                        rest,
  512|       |                        LogicalExpr::Comparison(ComparisonExpr {
  513|       |                            lhs: Comparable::Literal(lhs),
  514|       |                            op: comp_op,
  515|       |                            rhs,
  516|       |                        }),
  517|       |                    ));
  518|       |                }
  519|       |            }
  520|       |            Err(Err::Failure(err)) => return Err(Err::Failure(err)),
  521|       |            _ => (),
  522|       |        }
  523|       |
  524|       |        match filter_query(rest, ctx) {
  525|       |            Ok((rest, query)) => {
  526|       |                let query_len = q.len() - rest.len();
  527|       |                let rest = skip_whitespace(rest);
  528|       |                if let Ok((rest, comp_op)) = comparison_operator(rest) {
  529|       |                    let rest = skip_whitespace(rest);
  530|       |                    let (rest, rhs) = comparable(rest, ctx)?;
  531|       |                    let Some(singular_query) = query.try_to_comparable() else {
  532|       |                        return fail(SyntaxErrorKind::NonSingularQueryInComparison, q.len(), query_len, rest);
  533|       |                    };
  534|       |                    if negated {
  535|       |                        fail(SyntaxErrorKind::InvalidNegation, q.len(), 1, rest)
  536|       |                    } else {
  537|       |                        Ok((
  538|       |                            rest,
  539|       |                            LogicalExpr::Comparison(ComparisonExpr {
  540|       |                                lhs: singular_query,
  541|       |                                rhs,
  542|       |                                op: comp_op,
  543|       |                            }),
  544|       |                        ))
  545|       |                    }
  546|       |                } else {
  547|       |                    let test_expr = LogicalExpr::Test(query.into_test_query());
  548|       |                    let expr = if negated {
  549|       |                        LogicalExpr::Not(Box::new(test_expr))
  550|       |                    } else {
  551|       |                        test_expr
  552|       |                    };
  553|       |                    Ok((rest, expr))
  554|       |                }
  555|       |            }
  556|       |            Err(Err::Failure(err)) => Err(Err::Failure(err)),
  557|       |            _ => failed_filter_expression(SyntaxErrorKind::InvalidFilter)(rest),
  558|       |        }
  559|       |    }
