  451|  20.1k|            value(BooleanOp::And, tag("&&")),
  452|  20.1k|            value(BooleanOp::Or, tag("||")),
  453|  20.1k|        ))))
  454|  20.1k|        .parse(loop_rest)?;
  455|  20.1k|        loop_rest = rest;
  456|       |
  457|  5.15k|        match mb_boolean_op {
  458|       |            Some(BooleanOp::And) => {
  459|    888|                let (rest, rhs_expr) = ignore_whitespace(|q| parse_single(q, ctx))(loop_rest)?;
