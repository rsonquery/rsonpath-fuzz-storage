  480|       |            let Ok((rest, _)) = char::<_, ()>(')')(rest) else {
  481|       |                return failed_filter_expression(SyntaxErrorKind::MissingClosingParenthesis)(rest);
  482|       |            };
  483|       |            let selector = if negated {
