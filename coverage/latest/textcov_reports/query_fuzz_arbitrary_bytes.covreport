  838|       |                        0xD800..=0xDBFF => {
  839|       |                            let &(_, next) = chars.peek().ok_or(SyntaxError::new(
  840|       |                                SyntaxErrorKind::UnpairedHighSurrogate,
  841|       |                                q_len - c_idx,
  842|       |                                6,
  843|       |                            ))?;
  844|       |                            if next != '\\' {
  845|       |                                return Err(SyntaxError::new(
  846|       |                                    SyntaxErrorKind::UnpairedHighSurrogate,
  847|       |                                    q_len - c_idx,
  848|       |                                    6,
  849|       |                                ));
  850|       |                            }
  851|       |                            chars.next();
  852|       |                            let (i, next) = chars.next().ok_or(SyntaxError::new(
  853|       |                                SyntaxErrorKind::UnpairedHighSurrogate,
  854|       |                                q_len - c_idx,
  855|       |                                6,
  856|       |                            ))?;
  857|       |                            if next != 'u' {
  858|       |                                return Err(SyntaxError::new(
  859|       |                                    SyntaxErrorKind::UnpairedHighSurrogate,
  860|       |                                    q_len - c_idx,
  861|       |                                    6,
  862|       |                                ));
  863|       |                            }
  864|       |                            let low = read_hexadecimal_escape(q_len, i, chars)?;
  865|       |                            match low {
  866|       |                                0xDC00..=0xDFFF => {
  867|       |                                    let n = (((raw_c - 0xD800) << 10) | (low - 0xDC00)) + 0x10000;
  868|       |                                    Ok(char::from_u32(n).expect("high and low surrogate pair is always a valid char"))
  869|       |                                }
  870|       |                                _ => Err(SyntaxError::new(
  871|       |                                    SyntaxErrorKind::UnpairedHighSurrogate,
  872|       |                                    q_len - c_idx,
  873|       |                                    6,
  874|       |                                )),
  875|       |                            }
  876|       |                        }
  877|       |                        // Low surrogate, invalid escape sequence.
  878|       |                        0xDC00..=0xDFFF => Err(SyntaxError::new(
  879|       |                            SyntaxErrorKind::UnpairedLowSurrogate,
  880|       |                            q_len - c_idx,
  881|       |                            6,
  882|       |                        )),
  883|       |                        _ => Ok(char::from_u32(raw_c).expect("invalid values are handled above")),
  884|       |                    }
  885|       |                }
  886|       |                'b' => Ok('\u{0008}'), // U+0008 BS backspace
  887|       |                't' => Ok('\t'),       // U+0009 HT horizontal tab
  888|       |                'n' => Ok('\n'),       // U+000A LF line feed
  889|       |                'f' => Ok('\u{000C}'), // U+000C FF form feed
  890|       |                'r' => Ok('\r'),       // U+000D CR carriage return
  891|       |                '"' if mode == StringParseMode::DoubleQuoted => Ok(ctrl),
  892|       |                '\'' if mode == StringParseMode::SingleQuoted => Ok(ctrl),
  893|       |                '/' | '\\' => Ok(ctrl), // " ' / \ are passed as is
  894|       |                _ => Err(SyntaxError::new(
  895|       |                    SyntaxErrorKind::InvalidEscapeSequence,
  896|       |                    q_len - c_idx,
  897|       |                    2,
  898|       |                )), // no other escape sequences are allowed
  899|       |            }
  900|       |        }
