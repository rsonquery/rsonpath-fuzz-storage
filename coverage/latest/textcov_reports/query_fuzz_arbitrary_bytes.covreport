  660|  10.2k|fn failed_filter_expression<T>(kind: SyntaxErrorKind) -> impl FnMut(&str) -> IResult<&str, T, InternalParseError<'_>> {
  661|       |    move |q: &str| {
  662|       |        // We want to close the filter, so just try to find the next ']' or ','
