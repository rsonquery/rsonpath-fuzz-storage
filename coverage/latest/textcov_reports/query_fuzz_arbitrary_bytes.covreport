  446|  10.2k|    let mut loop_rest = skip_whitespace(rest);
  447|  10.2k|    let mut final_expr = this_expr;
  448|       |
  449|       |    loop {
  450|  12.9k|        let (rest, mb_boolean_op) = opt(ignore_whitespace(alt((
  451|  12.9k|            value(BooleanOp::And, tag("&&")),
  452|  12.9k|            value(BooleanOp::Or, tag("||")),
  453|  12.9k|        ))))
  454|  12.9k|        .parse(loop_rest)?;
  455|  12.9k|        loop_rest = rest;
  456|       |
  457|  3.35k|        match mb_boolean_op {
  458|       |            Some(BooleanOp::And) => {
  459|    467|                let (rest, rhs_expr) = ignore_whitespace(|q| parse_single(q, ctx))(loop_rest)?;
  460|    268|                loop_rest = rest;
  461|    268|                final_expr = LogicalExpr::And(Box::new(final_expr), Box::new(rhs_expr));
  462|       |            }
  463|       |            Some(BooleanOp::Or) => {
  464|  2.88k|                let (rest, rhs_expr) = ignore_whitespace(|q| logical_expr(q, ctx))(loop_rest)?;
  465|  2.45k|                loop_rest = rest;
  466|  2.45k|                final_expr = LogicalExpr::Or(Box::new(final_expr), Box::new(rhs_expr));
  467|       |            }
  468|  9.58k|            None => break,
  469|       |        }
  470|       |    }
  471|       |
  472|  9.58k|    return Ok((loop_rest, final_expr));
  473|       |
  474|       |    fn parse_single<'q>(q: &'q str, ctx: ParseCtx) -> IResult<&'q str, LogicalExpr, InternalParseError<'q>> {
  475|       |        let (rest, opt_neg) = ignore_whitespace(opt(char('!')))(q)?;
  476|       |        let negated = opt_neg.is_some();
  477|       |        if let Ok((rest, _)) = char::<_, ()>('(')(rest) {
  478|       |            let (rest, nested_filter) = cut(|q| logical_expr(q, ctx)).parse(skip_whitespace(rest))?;
