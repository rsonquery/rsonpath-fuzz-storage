  532|       |                        return fail(SyntaxErrorKind::NonSingularQueryInComparison, q.len(), query_len, rest);
  533|       |                    };
  534|       |                    if negated {
  535|       |                        fail(SyntaxErrorKind::InvalidNegation, q.len(), 1, rest)
  536|       |                    } else {
  537|       |                        Ok((
  538|       |                            rest,
  539|       |                            LogicalExpr::Comparison(ComparisonExpr {
  540|       |                                lhs: singular_query,
  541|       |                                rhs,
  542|       |                                op: comp_op,
  543|       |                            }),
  544|       |                        ))
  545|       |                    }
  546|       |                } else {
  547|       |                    let test_expr = LogicalExpr::Test(query.into_test_query());
  548|       |                    let expr = if negated {
  549|       |                        LogicalExpr::Not(Box::new(test_expr))
  550|       |                    } else {
