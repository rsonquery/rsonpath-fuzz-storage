  412|  43.2k|fn logical_expr<'q>(q: &'q str, ctx: ParseCtx) -> IResult<&'q str, LogicalExpr, InternalParseError<'q>> {
  413|       |    // This is the most involved part of the parser, as it is inherently recursive.
  414|       |    //
  415|       |    // There are two sources of recursion here: parentheses introduce recursion,
  416|       |    // since the rule is simply '(' filter_expression ')'; and the boolean combinations
  417|       |    // require checking for an operator, and if any is present recursively parsing
  418|       |    // another filter and wrapping the result in an appropriate node type.
  419|       |    //
  420|       |    // In total, we handle the negation operator at the start and then apply the rules:
  421|       |    // - '(' |=> filter_expression, ')'
  422|       |    // - literal |=> comp_op, comparable
  423|       |    // - query, comp_op |=> comparable
  424|       |    // - query
  425|       |    // where |=> means a cut. We separately apply two additional restrictions:
  426|       |    // - negation cannot immediately precede a comparison,
  427|       |    // - query in a comparison must be singular.
  428|       |    // It would be possible to directly disallow them by the rules, but if the parser understands
  429|       |    // these two special cases it can give much clearer error messages about them.
  430|       |    //
  431|       |    // At the end, we check for `&&` and `||``, recurse and wrap if needed; if not, we end parsing
  432|       |    // and leave the rest to the parsers higher up the stack. They might accept the next
  433|       |    // character (e.g. it's `)` called from a recursive filter call, `,` chaining selectors,
  434|       |    // `]` ending a segment...) and are responsible for error handling otherwise.
  435|       |    #[derive(Debug, Clone, Copy)]
  436|       |    enum BooleanOp {
  437|       |        And,
  438|       |        Or,
  439|       |    }
  440|       |
  441|  43.2k|    let Some(ctx) = ctx.increase_nesting() else {
  442|     75|        return Err(Err::Failure(InternalParseError::RecursionLimitExceeded));
  443|       |    };
  444|       |
  445|  43.2k|    let (rest, this_expr) = ignore_whitespace(|q| parse_single(q, ctx))(q)?;
  446|  13.2k|    let mut loop_rest = skip_whitespace(rest);
  447|  13.2k|    let mut final_expr = this_expr;
  448|       |
  449|       |    loop {
  450|  16.4k|        let (rest, mb_boolean_op) = opt(ignore_whitespace(alt((
  451|  16.4k|            value(BooleanOp::And, tag("&&")),
  452|  16.4k|            value(BooleanOp::Or, tag("||")),
  453|  16.4k|        ))))
  454|  16.4k|        .parse(loop_rest)?;
  455|  16.4k|        loop_rest = rest;
  456|       |
  457|  4.08k|        match mb_boolean_op {
  458|       |            Some(BooleanOp::And) => {
  459|    566|                let (rest, rhs_expr) = ignore_whitespace(|q| parse_single(q, ctx))(loop_rest)?;
  460|    271|                loop_rest = rest;
  461|    271|                final_expr = LogicalExpr::And(Box::new(final_expr), Box::new(rhs_expr));
  462|       |            }
  463|       |            Some(BooleanOp::Or) => {
  464|  3.51k|                let (rest, rhs_expr) = ignore_whitespace(|q| logical_expr(q, ctx))(loop_rest)?;
  465|  2.98k|                loop_rest = rest;
  466|  2.98k|                final_expr = LogicalExpr::Or(Box::new(final_expr), Box::new(rhs_expr));
  467|       |            }
  468|  12.3k|            None => break,
  469|       |        }
  470|       |    }
  471|       |
  472|  12.3k|    return Ok((loop_rest, final_expr));
  473|       |
  474|       |    fn parse_single<'q>(q: &'q str, ctx: ParseCtx) -> IResult<&'q str, LogicalExpr, InternalParseError<'q>> {
  475|       |        let (rest, opt_neg) = ignore_whitespace(opt(char('!')))(q)?;
  476|       |        let negated = opt_neg.is_some();
  477|       |        if let Ok((rest, _)) = char::<_, ()>('(')(rest) {
  478|       |            let (rest, nested_filter) = cut(|q| logical_expr(q, ctx)).parse(skip_whitespace(rest))?;
