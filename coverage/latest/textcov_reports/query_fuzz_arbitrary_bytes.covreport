  204|       |            fail(SyntaxErrorKind::EmptySelector, q.len() + 1, error_len + 2, rest)
  205|       |        } else {
  206|       |            // Don't highlight leading whitespace in an error.
  207|       |            let meaningful_span = skip_whitespace(error_span);
