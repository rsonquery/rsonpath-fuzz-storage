  494|       |                let (rest, comp_op) = match comparison_operator(rest) {
  495|       |                    Ok((rest, comp_op)) => (rest, comp_op),
  496|       |                    Err(Err::Failure(err)) => return Err(Err::Failure(err)),
  497|       |                    _ => {
