  517|  8.60k|    let (i, o) = self(i).map_err(|e| match e {
  518|       |      Err::Incomplete(i) => Err::Incomplete(i),
  519|       |      Err::Error(e) => Err::Error(OM::Error::bind(|| e)),
  520|       |      Err::Failure(e) => Err::Failure(e),
  521|  8.60k|    })?;
