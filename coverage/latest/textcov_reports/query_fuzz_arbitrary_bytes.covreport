  852|       |                            let (i, next) = chars.next().ok_or(SyntaxError::new(
  853|       |                                SyntaxErrorKind::UnpairedHighSurrogate,
  854|       |                                q_len - c_idx,
  855|       |                                6,
  856|       |                            ))?;
