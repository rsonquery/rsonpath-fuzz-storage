  494|       |                let (rest, comp_op) = match comparison_operator(rest) {
  495|       |                    Ok((rest, comp_op)) => (rest, comp_op),
  496|       |                    Err(Err::Failure(err)) => return Err(Err::Failure(err)),
  497|       |                    _ => {
  498|       |                        if peek(char::<_, ()>(']')).parse(rest).is_ok() {
  499|       |                            return fail(SyntaxErrorKind::MissingComparisonOperator, rest.len(), 1, rest);
  500|       |                        } else {
  501|       |                            return failed_filter_expression(SyntaxErrorKind::InvalidComparisonOperator)(rest);
  502|       |                        };
  503|       |                    }
  504|       |                };
  505|       |                let rest = skip_whitespace(rest);
