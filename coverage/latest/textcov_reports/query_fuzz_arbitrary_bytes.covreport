  465|  3.07k|                loop_rest = rest;
  466|  3.07k|                final_expr = LogicalExpr::Or(Box::new(final_expr), Box::new(rhs_expr));
  467|       |            }
  468|  14.9k|            None => break,
  469|       |        }
  470|       |    }
  471|       |
  472|  14.9k|    return Ok((loop_rest, final_expr));
  473|       |
  474|       |    fn parse_single<'q>(q: &'q str, ctx: ParseCtx) -> IResult<&'q str, LogicalExpr, InternalParseError<'q>> {
