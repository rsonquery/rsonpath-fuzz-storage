  185|  38.1k|fn failed_segment<T>(kind: SyntaxErrorKind) -> impl FnMut(&str) -> IResult<&str, T, InternalParseError<'_>> {
  186|       |    move |q: &str| {
  187|       |        // Special case when the error span starts with a bunch of periods.
  188|       |        // The best error message to display is to skip all those periods and try to recover after.
  189|       |        // This handles cases like e.g. `$....a`, where we will highlight `..a` as the error and
  190|       |        // try to continue from there. We also handle this as a separate suggestion to remove extraneous periods.
  191|       |        let rest = if q.starts_with('.') {
  192|       |            q.trim_start_matches('.')
  193|       |        } else {
  194|       |            skip_one(q)
  195|       |        }
  196|       |        .trim_start_matches(|x| x != '.' && x != '[');
  197|       |        // Don't highlight leading whitespace in an error.
  198|       |        // This logic is duplicated with failed_selector, but I didn't find a way to extract this logic that wouldn't
  199|       |        // make it actually *harder* to follow wtf is happening in the code, so...
  200|       |        let error_len = q.len() - rest.len();
  201|       |        let error_span = &q[..error_len];
  202|       |        if error_span.chars().all(|x| [' ', '\n', '\r', '\t'].contains(&x)) {
  203|       |            // Special case for a completely empty selector where we don't want to ignore whitespace.
  204|       |            fail(SyntaxErrorKind::EmptySelector, q.len() + 1, error_len + 2, rest)
  205|       |        } else {
  206|       |            // Don't highlight leading whitespace in an error.
  207|       |            let meaningful_span = skip_whitespace(error_span);
  208|       |            let skipped_whitespace_len = error_span.len() - meaningful_span.len();
  209|       |            let trimmed_span = meaningful_span.trim_end_matches(JSONPATH_WHITESPACE);
  210|       |            fail(kind.clone(), q.len() - skipped_whitespace_len, trimmed_span.len(), rest)
  211|       |        }
  212|       |    }
  213|  38.1k|}
