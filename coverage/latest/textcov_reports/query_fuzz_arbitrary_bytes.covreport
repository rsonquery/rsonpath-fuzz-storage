  902|       |        fn read_hexadecimal_escape<I>(
  903|       |            q_len: usize,
  904|       |            c_idx: usize,
  905|       |            chars: &mut Peekable<I>,
  906|       |        ) -> std::result::Result<u32, SyntaxError>
  907|       |        where
  908|       |            I: Iterator<Item = (usize, char)>,
  909|       |        {
  910|       |            let mut x = 0;
  911|       |            for i in 0..4 {
  912|       |                let &(_, c) = chars.peek().ok_or(SyntaxError::new(
  913|       |                    SyntaxErrorKind::InvalidEscapeSequence,
  914|       |                    q_len - c_idx + 1,
  915|       |                    2 + i,
  916|       |                ))?;
  917|       |                let v = match c {
  918|       |                    '0'..='9' => c as u32 - '0' as u32,
  919|       |                    // RFC8259.7-2 The hexadecimal letters A through F can be uppercase or lowercase.
  920|       |                    'a'..='f' => c as u32 - 'a' as u32 + 10,
  921|       |                    'A'..='F' => c as u32 - 'A' as u32 + 10,
  922|       |                    _ => {
  923|       |                        return Err(SyntaxError::new(
  924|       |                            SyntaxErrorKind::InvalidHexDigitInUnicodeEscape,
  925|       |                            q_len - c_idx - i - 1,
  926|       |                            1,
  927|       |                        ))
  928|       |                    }
  929|       |                };
  930|       |                x <<= 4;
  931|       |                x += v;
  932|       |                chars.next();
  933|       |            }
  934|       |            Ok(x)
  935|       |        }
