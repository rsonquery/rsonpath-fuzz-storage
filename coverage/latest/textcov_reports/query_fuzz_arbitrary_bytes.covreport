  516|  4.77k|  fn process<OM: OutputMode>(&mut self, i: I) -> PResult<OM, I, Self::Output, Self::Error> {
  517|  4.77k|    let (i, o) = self(i).map_err(|e| match e {
  518|       |      Err::Incomplete(i) => Err::Incomplete(i),
  519|       |      Err::Error(e) => Err::Error(OM::Error::bind(|| e)),
  520|       |      Err::Failure(e) => Err::Failure(e),
  521|  4.77k|    })?;
